# Configuration for compose/*.yml files.
#
# KAINE requires authentication on every container it operates so the
# same checkout is safe to ship to a future network-attached deployment.
# Build prompt §1.1 mandates this; see kaine/bus/AUDIT.md for the
# threat model.
#
# Easiest path (recommended): run the bootstrap scripts. They generate
# a fresh credential, write compose/.env atomically, mirror into
# config/secrets.toml, and bring the container up:
#
#   bash scripts/redis-bootstrap.sh
#   bash scripts/qdrant-bootstrap.sh
#
# Manual path: copy this file to compose/.env and REPLACE the commented
# placeholders below. The placeholders are intentionally commented so a
# `cp` + `echo >>` workflow doesn't produce a duplicate-key file.
#
# Mirror the same values into config/secrets.toml under the matching
# section so KAINE can connect.

# --- Redis (event bus) ---
# KAINE_REDIS_PASSWORD=replace-me-with-a-strong-random-password
# KAINE_REDIS_HOST_PORT=6479

# --- Qdrant (Mnemos vector memory) ---
# KAINE_QDRANT_API_KEY=replace-me-with-a-strong-random-api-key
# KAINE_QDRANT_HOST_PORT=6533

# ======================================================================
# Full topology (compose/kaine.yml) — see docs/deployment-containers.md
# ======================================================================

# --- Image flavor + tags ---
# KAINE_FLAVOR=cuda                 # cuda | cpu | rocm | xpu (build-time torch)
# KAINE_IMAGE=kaine:cuda            # override the built image tag

# --- Model service images (parameterized; override to use vLLM/your builds) ---
# KAINE_MODEL_SERVER_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
# KAINE_SPEACHES_IMAGE=ghcr.io/speaches-ai/speaches:latest-cpu
# KAINE_CHATTERBOX_IMAGE=kaine-chatterbox:local

# --- Loopback host ports ---
# KAINE_MODEL_SERVER_HOST_PORT=11434
# KAINE_SPEACHES_HOST_PORT=8000
# KAINE_CHATTERBOX_HOST_PORT=8883
# KAINE_NEXUS_HOST_PORT=8088

# --- GPU device pinning (two-GPU split: organ card 0, vision/TTS card 1) ---
# KAINE_ORGAN_GPU=0
# KAINE_VISION_GPU=1

# --- Model server + state secrets ---
# KAINE_MODEL_SERVER_API_KEY=replace-me-if-your-server-requires-auth
# KAINE_STATE_KEY=                  # 32-byte AES-256 key for encryption-at-rest

# --- Boot gates: NEVER defaulted permissive. Set only to boot the entity. ---
# KAINE_CYCLE_OPERATOR_PRESENT=1    # required to boot the cognitive cycle
# KAINE_RESEARCH_MODE=1             # unsupervised research (requires safety net)
